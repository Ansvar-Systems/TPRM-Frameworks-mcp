{
  "_comment": "TPRM Frameworks MCP Server Configuration for Ansvar AI Platform",
  "_instructions": "Add this configuration to your Ansvar AI MCP configuration file",
  "_version": "0.1.0",
  "_date": "2026-02-07",

  "mcpServers": {
    "tprm-frameworks": {
      "command": "python3",
      "args": ["-m", "tprm_frameworks_mcp"],
      "env": {
        "TPRM_PORT": "8309",
        "TPRM_LOG_LEVEL": "INFO",
        "PYTHONUNBUFFERED": "1"
      },
      "description": "TPRM Frameworks MCP server for vendor risk assessments",
      "capabilities": {
        "tools": true,
        "resources": false,
        "prompts": false
      },
      "metadata": {
        "name": "TPRM Frameworks",
        "version": "0.1.0",
        "port": 8309,
        "protocol": "stdio",
        "tools_count": 7,
        "frameworks_count": 4,
        "integration_servers": [
          "security-controls-mcp (port 8308)",
          "eu-regulations-mcp"
        ],
        "health_check_enabled": true,
        "health_check_interval_seconds": 60
      }
    }
  }
}

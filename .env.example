# TPRM Frameworks MCP - Environment Configuration

# Server Configuration
TPRM_PORT=8309
TPRM_LOG_LEVEL=INFO
TPRM_LOG_FORMAT=json

# Risk Evaluation Thresholds
RISK_LOW_THRESHOLD=80.0
RISK_MEDIUM_THRESHOLD=60.0
RISK_HIGH_THRESHOLD=40.0

# Storage Configuration
TPRM_DB_PATH=/Users/username/.tprm-mcp/tprm.db

# Integration Configuration
# EU Regulations MCP Server URL
# Format for stdio: "command:args" (e.g., "python3:/opt/eu-regulations-mcp/server.py")
# Format for HTTP: "http://localhost:8000" (not yet implemented)
# Leave empty to use local data only
EU_REGULATIONS_MCP_URL=

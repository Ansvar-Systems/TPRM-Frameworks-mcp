      "id": "sig_lite_1.1",
      "category": "Information Security Policy",
      "subcategory": "Governance",
      "question_text": "Does your organization have a documented and board-approved information security policy?",
      "description": "Information security policy should be formally documented, approved by senior management or board, and communicated to all relevant personnel.",
      "expected_answer_type": "yes_no",
      "is_required": true,
      "weight": 9,
      "regulatory_mappings": ["ISO 27001:2022 - 5.2", "SOC 2 - CC1.1", "DORA - ICT Risk Management"],
      "scf_control_mappings": ["GOV-01", "GOV-03"],
      "risk_if_inadequate": "high",
      "evaluation_rubric": {
        "acceptable": ["yes", "we have.*policy.*approved", "board.*approved.*policy"],
        "partially_acceptable": ["policy exists.*not.*board", "documented.*awaiting approval"],
        "unacceptable": ["no", "not.*have.*policy", "informal.*policy"],
        "required_keywords": ["documented", "approved"]
      }
    },
    {

{
  "manifest_version": "0.3",
  "name": "tprm-frameworks-mcp",
  "display_name": "TPRM Frameworks MCP Server",
  "version": "1.0.0",
  "description": "MCP server for TPRM workflows - questionnaire generation, vendor assessment, and compliance mapping",
  "author": {
    "name": "Ansvar Systems",
    "email": "hello@ansvar.eu",
    "url": "https://ansvar.eu"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ansvar-Systems/TPRM-Frameworks-mcp"
  },
  "homepage": "https://ansvar.eu",
  "keywords": ["mcp", "tprm", "vendor-risk", "sig", "caiq", "dora", "nis2", "third-party-risk"],
  "server": {
    "type": "python",
    "entry_point": "run.py",
    "mcp_config": {
      "command": "python3",
      "args": ["${__dirname}/run.py"],
      "env": {
        "PYTHONPATH": "${__dirname}/src:${__dirname}/lib"
      }
    }
  },
  "tools": [
    "list_frameworks",
    "generate_questionnaire",
    "evaluate_response",
    "map_questionnaire_to_controls",
    "generate_tprm_report",
    "get_questionnaire",
    "search_questions",
    "get_vendor_history",
    "compare_assessments",
    "generate_dora_questionnaire",
    "generate_nis2_questionnaire",
    "check_regulatory_compliance",
    "get_regulatory_timeline",
    "upload_evidence_document",
    "list_evidence_documents",
    "validate_evidence_document"
  ],
  "compatibility": {
    "platforms": ["darwin", "win32", "linux"],
    "runtimes": {
      "python": ">=3.10"
    }
  }
}
